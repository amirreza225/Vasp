{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "types": ["node"],
    "lib": ["ES2022"],
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ES2022"
  },
  "references": [{ "path": "../core" }, { "path": "../parser" }],
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "src/__test_output__"]
}
