app A {
  title: "T"
  db: Drizzle
  ssr: false
  typescript: false
}

route R {
  path: "/"
  to: P
}

page P {
  component: import P from "@src/pages/P.vue"
}

action registerUser {
  fn: import { registerUser } from "@src/actions.js"
  entities: []
  onSuccess: {
    sendEmail: welcome
  }
}

email Mailer {
  provider: resend
  from: "noreply@myapp.com"
  templates: {
    welcome: import { welcomeTemplate } from "@src/emails/welcome.js"
  }
}
