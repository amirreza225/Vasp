{
  "name": "@vasp-framework/generator",
  "version": "1.3.2",
  "description": "Code generator: produces Elysia backend, Vue/Nuxt frontend, and @vasp-framework/client SDK from a VaspAST",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@vasp-framework/core": "workspace:*",
    "@vasp-framework/parser": "workspace:*",
    "handlebars": "^4.7.8"
  },
  "devDependencies": {
    "@types/handlebars": "^4.1.0",
    "typescript": "*",
    "vitest": "*"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/amirreza225/Vasp"
  },
  "module": "./dist/index.js"
}
