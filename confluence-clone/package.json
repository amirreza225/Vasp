{
  "name": "confluence-clone",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vasp start",
    "build": "vasp build",
    "test": "vitest run",
    "dev:server": "bun --hot server/index.ts",
    "dev:client": "nuxt dev --port 3000",
    "dev:admin": "bun run --cwd admin dev",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:push": "bunx drizzle-kit push",
    "db:studio": "bunx drizzle-kit studio",
    "db:seed": "bun server/db/seed.ts"
  },
  "dependencies": {
    "@vasp-framework/runtime": "^1.0.0",
    "elysia": "^1.1.0",
    "@elysiajs/cors": "^1.1.0",
    "@elysiajs/static": "^1.1.0",
    "@elysiajs/swagger": "^1.1.0",
    "@elysiajs/jwt": "^1.1.0",
    "jose": "^5.0.0",
    "valibot": "^1.0.0",
    "drizzle-orm": "^0.36.0",
    "postgres": "^3.4.0",
    "ofetch": "^1.3.4",
    "vue": "^3.5.0",
    "primevue": "^4.3.0",
    "@primevue/themes": "^4.3.0",
    "@primevue/forms": "^4.3.0",
    "primeicons": "^7.0.0",
    "@tiptap/vue-3": "^2.10.0",
    "@tiptap/starter-kit": "^2.10.0",
    "@tiptap/extension-placeholder": "^2.10.0",
    "nuxt": "^4.0.0",
    "@primevue/nuxt-module": "^4.3.0",
    "pg-boss": "^10.0.0",
    "resend": "^4.0.0",
