DATABASE_URL=postgres://user:password@localhost:5432/confluence-clone

# ── Ports & URLs ──────────────────────────────────────────────────────────────
PORT=3001                                    # Elysia backend (API server)
VITE_API_URL=http://localhost:3001/api       # Backend URL used by the frontend to call the API
CORS_ORIGIN=http://localhost:3000           # Frontend URL the backend allows (CORS allow-list)
JWT_SECRET=change-me-in-production-minimum-32-chars
RESEND_API_KEY=
# ── OpenTelemetry ────────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=confluence-clone
OTEL_SERVICE_VERSION=1.0.0
# ── E2E Testing ───────────────────────────────────────────────────────────────
# Set this to a random secret to enable the E2E auth bypass header.
# Leave empty in production. Bypass only works when NODE_ENV != production.
E2E_MAGIC_TOKEN=
