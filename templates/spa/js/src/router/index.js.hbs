import { createRouter, createWebHistory } from 'vue-router'
{{#if hasAuth}}
import { useAuth } from '../vasp/auth.js'
{{/if}}

const routes = [
{{#each routes}}
  {
    path: '{{path}}',
    component: () => import('{{lookup ../pagesMap to}}'),
  },
{{/each}}
{{#each autoPages}}
  {
    path: '{{path}}',
    component: () => import('../pages/{{name}}.vue'),
    {{#if auth}}
    meta: { requiresAuth: true{{#if roles}}, roles: [{{#each roles}}'{{this}}'{{#unless @last}}, {{/unless}}{{/each}}]{{/if}} },
    {{/if}}
  },
{{/each}}
{{#if hasAdmin}}
  {
    path: '/admin',
    component: () => import('../admin/AdminLayout.vue'),
    {{#if hasAuth}}
    meta: { requiresAuth: true },
    {{/if}}
    children: [
      {
        path: '',
        component: () => import('../admin/views/Dashboard.vue'),
      },
{{#each adminEntities}}
      {
        path: '{{kebabCase name}}',
        component: () => import('../admin/views/{{kebabCase name}}/index.vue'),
      },
{{/each}}
    ],
  },
{{/if}}
{{#if hasAuth}}
  {
    path: '/login',
    component: () => import('@src/pages/Login.vue'),
  },
  {
    path: '/register',
    component: () => import('@src/pages/Register.vue'),
  },
{{/if}}
  { path: '/:pathMatch(.*)*', name: 'NotFound', component: () => import('../pages/NotFound.vue') },
]

const router = createRouter({
  history: createWebHistory(),
  routes,
})

{{#if hasAuth}}
router.beforeEach(async (to) => {
  const { user, checkAuth } = useAuth()
  await checkAuth()
  const publicPaths = ['/login', '/register']
  if (!user.value && !publicPaths.includes(to.path)) {
    return '/login'
  }
})
{{/if}}

export default router
