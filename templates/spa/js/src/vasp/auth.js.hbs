import { ref } from 'vue'
import { $fetch } from 'ofetch'
import { notifyError } from './useVaspNotifications.js'

const user = ref(null)
let checked = false

const API = import.meta.env.VITE_API_URL || '/api'

export function useAuth() {
  async function checkAuth() {
    if (checked) return
    checked = true
    try {
      user.value = await $fetch(`${API}/auth/me`, { credentials: 'include' })
    } catch {
      user.value = null
    }
  }

  async function login(username, password) {
    try {
      user.value = await $fetch(`${API}/auth/login`, {
        method: 'POST',
        body: { username, password },
        credentials: 'include',
      })
      return user.value
    } catch (error) {
      notifyError(error)
      throw error
    }
  }

  async function register(username, password, email, extras = {}) {
    try {
      user.value = await $fetch(`${API}/auth/register`, {
        method: 'POST',
        body: { username, password, email, ...extras },
        credentials: 'include',
      })
      return user.value
    } catch (error) {
      notifyError(error)
      throw error
    }
  }

  async function logout() {
    try {
      await $fetch(`${API}/auth/logout`, { method: 'POST', credentials: 'include' })
      user.value = null
      checked = false
    } catch (error) {
      notifyError(error)
      throw error
    }
  }

  return { user, checkAuth, login, register, logout }
}
