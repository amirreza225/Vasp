<script setup{{#if isTypeScript}} lang="ts"{{/if}}>
import { ref, onMounted } from 'vue'
import { useRouter } from 'vue-router'
import DataTable from 'primevue/datatable'
import Column from 'primevue/column'
import Button from 'primevue/button'
import InputText from 'primevue/inputtext'
import Tag from 'primevue/tag'
import IconField from 'primevue/iconfield'
import InputIcon from 'primevue/inputicon'
import { useConfirm } from 'primevue/useconfirm'
import { useToast } from 'primevue/usetoast'
import { FilterMatchMode } from '@primevue/core/api'

const router = useRouter()
const confirm = useConfirm()
const toast = useToast()

const rows = ref([])
const loading = ref(true)
const filters = ref({
  global: { value: null, matchMode: FilterMatchMode.CONTAINS }
})

async function load() {
  loading.value = true
  try {
    const res = await fetch('/api/{{kebabCase entityNamePascal}}')
    rows.value = await res.json()
  } finally {
    loading.value = false
  }
}

onMounted(load)

{{#if hasDeleteRow}}
function confirmDelete(id) {
  confirm.require({
    message: 'Are you sure you want to delete this record?',
    header: 'Confirm',
    icon: 'pi pi-exclamation-triangle',
    rejectProps: { label: 'Cancel', severity: 'secondary', outlined: true },
    acceptProps: { label: 'Delete', severity: 'danger' },
    accept: async () => {
      await fetch('/api/{{kebabCase entityNamePascal}}/' + id, { method: 'DELETE' })
      toast.add({ severity: 'success', summary: 'Deleted', life: 3000 })
      await load()
    }
  })
}
{{/if}}
</script>

<template>
  <div class="p-6">
    <DataTable
      :value="rows"
      :loading="loading"
      {{#if hasPaginate}}
      paginator
      :rows="{{pageSize}}"
      :rowsPerPageOptions="[10, 20, 50, 100]"
      paginatorTemplate="FirstPageLink PrevPageLink PageLinks NextPageLink LastPageLink RowsPerPageDropdown"
      {{/if}}
      v-model:filters="filters"
      {{#if hasSearchable}}
      filterDisplay="menu"
      {{/if}}
      sortMode="multiple"
      removableSort
      stripedRows
      tableStyle="min-width: 50rem"
    >
      <template #header>
        <div class="flex justify-between items-center gap-4 flex-wrap">
          <h1 class="text-2xl font-semibold m-0">{{pageTitle}}</h1>
          <div class="flex gap-2 items-center">
            {{#if hasSearchable}}
            <IconField>
              <InputIcon class="pi pi-search" />
              <InputText v-model="filters['global'].value" placeholder="Search..." />
            </IconField>
            {{/if}}
            {{#if hasCreate}}
            <Button
              label="New {{entityNamePascal}}"
              icon="pi pi-plus"
              @click="router.push('{{autoPage.path}}/create')"
            />
            {{/if}}
            {{#if hasExport}}
            <Button
              label="Export"
              icon="pi pi-download"
              severity="secondary"
              outlined
            />
            {{/if}}
          </div>
        </div>
      </template>

      <template #empty>No records found.</template>
      <template #loading>Loading data...</template>

      {{#each resolvedColumns}}
      <Column
        field="{{key}}"
        header="{{label}}"
        {{#if sortable}}sortable{{/if}}
        style="min-width: 10rem"
      >
        {{#if (eq columnType "date")}}
        <template #body="{ data }">
          <time v-if="data.{{key}}" :datetime="data.{{key}}">\{{ new Date(data.{{key}}).toLocaleDateString() }}</time>
          <span v-else>—</span>
        </template>
        {{/if}}
        {{#if (eq columnType "boolean")}}
        <template #body="{ data }">
          <i :class="data.{{key}} ? 'pi pi-check text-green-500' : 'pi pi-times text-red-500'" />
        </template>
        {{/if}}
        {{#if (eq columnType "badge")}}
        <template #body="{ data }">
          <Tag :value="data.{{key}}" />
        </template>
        {{/if}}
      </Column>
      {{/each}}

      {{#if hasRowActions}}
      <Column header="Actions" style="min-width: 12rem">
        <template #body="{ data }">
          <div class="flex gap-2">
            {{#if hasViewRow}}
            <Button
              icon="pi pi-eye"
              severity="secondary"
              rounded
              outlined
              size="small"
              @click="router.push('{{autoPage.path}}/' + data.id)"
            />
            {{/if}}
            {{#if hasEditRow}}
            <Button
              icon="pi pi-pencil"
              rounded
              outlined
              size="small"
              @click="router.push('{{autoPage.path}}/' + data.id + '/edit')"
            />
            {{/if}}
            {{#if hasDeleteRow}}
            <Button
              icon="pi pi-trash"
              severity="danger"
              rounded
              outlined
              size="small"
              @click="confirmDelete(data.id)"
            />
            {{/if}}
          </div>
        </template>
      </Column>
      {{/if}}
    </DataTable>
  </div>
</template>
