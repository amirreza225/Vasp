{
  "name": "{{kebabCase appName}}",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vasp start",
    "build": "vasp build",
    "test": "vitest run",
    "dev:server": "bun --hot server/index.{{ext}}",
    "dev:client": "{{#if isSpa}}vite{{else}}nuxt dev{{/if}}",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:push": "bunx drizzle-kit push",
    "db:studio": "bunx drizzle-kit studio"{{#if seed}},
    "db:seed": "bun server/db/seed.{{ext}}"{{/if}}
  },
  "dependencies": {
    "@vasp-framework/runtime": "^0.1.0",
    "elysia": "^1.1.0",
    "@elysiajs/cors": "^1.1.0",
    "@elysiajs/static": "^1.1.0",{{#if auth}}
    "@elysiajs/jwt": "^1.1.0",
    "jose": "^5.0.0",{{/if}}
    "@elysiajs/valibot": "^1.1.0",
    "valibot": "^1.0.0",
    "drizzle-orm": "^0.36.0",
    "postgres": "^3.4.0",
    "ofetch": "^1.3.4",
    "vue": "^3.5.0"{{#if isSpa}},
    "vue-router": "^4.4.0"{{else}},
    "nuxt": "^4.0.0"{{/if}}{{#if hasJobs}},
    "pg-boss": "^10.0.0"{{/if}}
  },
  "devDependencies": {
    "drizzle-kit": "^0.28.0",
    "vitest": "^2.1.9"{{#if isSpa}},
    "@vitejs/plugin-vue": "^5.2.0",
    "vite": "^6.0.0"{{/if}}{{#if isTypeScript}},
    "typescript": "^5.6.0",
    "vue-tsc": "^2.0.0"{{/if}}
  }
}
