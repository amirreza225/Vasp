{
  "name": "{{kebabCase appName}}",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vasp start",
    "build": "vasp build",
    "test": "vitest run",
    "dev:server": "bun --hot server/index.{{ext}}",
    "dev:client": "{{#if isSpa}}vite{{else}}nuxt dev --port {{frontendPort}}{{/if}}",{{#if hasAdmin}}
    "dev:admin": "bun run --cwd admin dev",{{/if}}
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:push": "bunx drizzle-kit push",
    "db:studio": "bunx drizzle-kit studio"{{#if seed}},
    "db:seed": "bun server/db/seed.{{ext}}"{{/if}}
  },
  "dependencies": {
    "@vasp-framework/runtime": "^1.0.0",
    "elysia": "^1.1.0",
    "@elysiajs/cors": "^1.1.0",
    "@elysiajs/static": "^1.1.0",
    "@elysiajs/swagger": "^1.1.0",{{#if auth}}
    "@elysiajs/jwt": "^1.1.0",
    "jose": "^5.0.0",{{/if}}
    "valibot": "^1.0.0",
    "drizzle-orm": "^0.36.0",
    "postgres": "^3.4.0",
    "ofetch": "^1.3.4",
    "vue": "^3.5.0",
    "primevue": "^4.3.0",
    "@primevue/themes": "^4.3.0",
    "@primevue/forms": "^4.3.0",
    "primeicons": "^7.0.0",
    "@tiptap/vue-3": "^2.10.0",
    "@tiptap/starter-kit": "^2.10.0",
    "@tiptap/extension-placeholder": "^2.10.0"{{#if isSpa}},
    "vue-router": "^4.4.0"{{else}},
    "nuxt": "^4.0.0",
    "@primevue/nuxt-module": "^4.3.0"{{/if}}{{#if hasPgBossJobs}},
    "pg-boss": "^10.0.0"{{/if}}{{#if hasRedisJobs}},
    "ioredis": "^5.0.0"{{/if}}{{#if hasBullMQJobs}},
    "bullmq": "^5.0.0"{{/if}}{{#if hasRabbitMQJobs}},
    "amqplib": "^0.10.0"{{/if}}{{#if hasKafkaJobs}},
    "kafkajs": "^2.0.0"{{/if}}{{#if hasEmailResend}},
    "resend": "^4.0.0"{{/if}}{{#if hasEmailSendgrid}},
    "@sendgrid/mail": "^8.0.0"{{/if}}{{#if hasEmailSmtp}},
    "nodemailer": "^6.9.0"{{/if}}{{#if hasObservability}},
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-node": "^0.57.0",
    "@opentelemetry/auto-instrumentations-node": "^0.56.0",
    "@opentelemetry/resources": "^1.30.0",
    "@opentelemetry/semantic-conventions": "^1.30.0"{{#if hasObservabilityOtlp}},
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.0"{{/if}}{{#if hasObservabilityMetrics}},
    "@opentelemetry/sdk-metrics": "^1.30.0"{{#if hasObservabilityPrometheus}},
    "@opentelemetry/exporter-prometheus": "^0.57.0"{{/if}}{{/if}}{{#if hasObservabilitySentry}},
    "@sentry/bun": "^9.0.0"{{/if}}{{#if hasObservabilityDatadog}},
    "dd-trace": "^5.0.0"{{/if}}{{/if}}{{#if hasCloudStorage}},
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0"{{/if}}{{#if hasCacheRedis}},
    "redis": "^4.0.0"{{/if}}
  },
  "devDependencies": {
    "drizzle-kit": "^0.28.0",
    "vitest": "^2.1.9"{{#if isSpa}},
    "@vitejs/plugin-vue": "^5.2.0",
    "vite": "^6.0.0"{{/if}}{{#if isTypeScript}},
    "typescript": "^5.6.0",
    "vue-tsc": "^2.0.0",
    "@types/node": "^22.0.0",
    "@types/bun": "^1.1.0"{{#if hasEmailSmtp}},
    "@types/nodemailer": "^6.4.0"{{/if}}{{#if hasRabbitMQJobs}},
    "@types/amqplib": "^0.10.0"{{/if}}{{/if}}
  }
}
