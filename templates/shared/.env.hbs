DATABASE_URL=postgres://user:password@localhost:5432/{{kebabCase appName}}
PORT={{backendPort}}
VITE_API_URL=http://localhost:{{backendPort}}/api
CORS_ORIGIN=http://localhost:{{frontendPort}}
{{#if hasAuth}}
JWT_SECRET=change-me-in-production-minimum-32-chars
{{#if (includes authMethods "google")}}
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
{{/if}}
{{#if (includes authMethods "github")}}
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
{{/if}}
{{/if}}
{{#if hasBullMQJobs}}
# ── BullMQ / Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
{{/if}}
{{#if hasRedisStreamsJobs}}
# ── Redis Streams ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
{{/if}}
{{#if hasRabbitMQJobs}}
# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672
{{/if}}
{{#if hasKafkaJobs}}
# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID={{kebabCase appName}}
{{/if}}
{{#if hasEmailResend}}
RESEND_API_KEY=
{{/if}}
{{#if hasEmailSendgrid}}
SENDGRID_API_KEY=
{{/if}}
{{#if hasEmailSmtp}}
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
{{/if}}
{{#if hasObservability}}
# ── OpenTelemetry ────────────────────────────────────────────────────────────
OTEL_SERVICE_NAME={{kebabCase appName}}
OTEL_SERVICE_VERSION=1.0.0
{{#if hasObservabilityOtlp}}
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_HEADERS=
{{/if}}
{{#if hasObservabilitySentry}}
SENTRY_DSN=
{{/if}}
{{/if}}
# ── E2E Testing ───────────────────────────────────────────────────────────────
# Set this to a random secret to enable the E2E auth bypass header.
# Leave empty in production. Bypass only works when NODE_ENV != production.
E2E_MAGIC_TOKEN=
