{{#if hasAnyTables}}
import { pgTable, text, integer, boolean, timestamp, doublePrecision, jsonb{{#if hasEnums}}, pgEnum{{/if}}{{#if hasAnyIndexes}}, index, uniqueIndex{{/if}} } from 'drizzle-orm/pg-core'
{{else}}{{#if hasEnums}}
import { pgEnum } from 'drizzle-orm/pg-core'
{{/if}}{{/if}}
{{#if hasAnyRelations}}
import { relations } from 'drizzle-orm'
{{/if}}
{{#if hasAnyFulltextIndexes}}
import { sql } from 'drizzle-orm'
{{/if}}
{{#if isTypeScript}}
{{#if hasAnyTables}}
import type { InferSelectModel, InferInsertModel } from 'drizzle-orm'
{{/if}}
{{/if}}

{{#if hasEnums}}
{{#each enumDeclarations}}
export const {{fnName}} = pgEnum('{{dbName}}', [{{#each values}}'{{this}}'{{#unless @last}}, {{/unless}}{{/each}}])
{{/each}}
{{/if}}
{{#if hasAuth}}
// {{authUserEntityName}} table — generated by Vasp auth system
export const {{userTableName}} = pgTable('{{userTableName}}', {
  id: integer('id').primaryKey().generatedByDefaultAsIdentity(),
  username: text('username').notNull().unique(),
  email: text('email').unique(),
  passwordHash: text('password_hash'),
  googleId: text('google_id').unique(),
  githubId: text('github_id').unique(),
{{#each authUserExtraFields}}
{{#if isEnum}}
  {{camelCase name}}: {{enumFnName}}('{{camelCase name}}'){{#unless nullable}}.notNull(){{/unless}}{{#if defaultValue}}.default('{{defaultValue}}'){{/if}},
{{else}}
  {{camelCase name}}: {{{drizzleColumn name type modifiers nullable defaultValue isUpdatedAt}}},
{{/if}}
{{/each}}
  createdAt: timestamp('created_at').defaultNow().notNull(),
  updatedAt: timestamp('updated_at').defaultNow().notNull(),
})
{{#if isTypeScript}}
export type {{pascalCase authUserEntityName}} = InferSelectModel<typeof {{userTableName}}>
export type New{{pascalCase authUserEntityName}} = InferInsertModel<typeof {{userTableName}}>
{{/if}}

{{/if}}
{{#each entitiesWithSchema}}
// {{name}} table — generated from entity block
export const {{plural (camelCase name)}} = pgTable('{{plural (camelCase name)}}', {
{{#each scalarFields}}
{{#if isForeignKey}}
  {{camelCase name}}: integer('{{camelCase name}}'){{#unless nullable}}.notNull(){{/unless}}.references(() => {{referencedTable}}.id, { onDelete: '{{onDelete}}' }),
{{else}}
{{#if isEnum}}
  {{camelCase name}}: {{enumFnName}}('{{camelCase name}}'){{#unless nullable}}.notNull(){{/unless}},
{{else}}
  {{camelCase name}}: {{{drizzleColumn name type modifiers nullable defaultValue isUpdatedAt}}},
{{/if}}
{{/if}}
{{/each}}
  createdAt: timestamp('created_at').defaultNow().notNull(),
  updatedAt: timestamp('updated_at').defaultNow().notNull(),
}{{#if hasTableIndexes}}, (t) => [
{{#each tableIndexes}}
{{#if isFulltext}}
  index('{{name}}').using('gin', sql`{{{fulltextSqlExpr}}}`),
{{else}}
  index('{{name}}').on({{#each fields}}t.{{this}}{{#unless @last}}, {{/unless}}{{/each}}),
{{/if}}
{{/each}}
{{#each tableUniqueConstraints}}
  uniqueIndex('{{name}}').on({{#each fields}}t.{{this}}{{#unless @last}}, {{/unless}}{{/each}}),
{{/each}}
]{{/if}})
{{#if ../isTypeScript}}
export type {{pascalCase name}} = InferSelectModel<typeof {{plural (camelCase name)}}>
export type New{{pascalCase name}} = InferInsertModel<typeof {{plural (camelCase name)}}>
{{/if}}

{{/each}}
{{#if hasAuth}}{{#if authUserHasRelations}}
export const {{userTableName}}Relations = relations({{userTableName}}, ({ one, many }) => ({
{{#each authUserManyToOne}}  {{camelCase name}}: one({{relatedTable}}, { fields: [{{../userTableName}}.{{camelCase localField}}], references: [{{relatedTable}}.id] }),
{{/each}}{{#each authUserOneToMany}}  {{camelCase fieldName}}: many({{relatedTable}}),
{{/each}}
}))
{{/if}}{{/if}}
{{#each entitiesWithSchema}}{{#if hasRelations}}
export const {{plural (camelCase name)}}Relations = relations({{plural (camelCase name)}}, ({ one, many }) => ({
{{#each manyToOne}}  {{camelCase name}}: one({{relatedTable}}, { fields: [{{plural (camelCase ../name)}}.{{camelCase localField}}], references: [{{relatedTable}}.id] }),
{{/each}}{{#each oneToMany}}  {{camelCase fieldName}}: many({{relatedTable}}),
{{/each}}
}))
{{/if}}{{/each}}
{{#unless hasAnyTables}}{{#unless hasEnums}}
// No entities defined — export an empty object so this file is a valid module.
