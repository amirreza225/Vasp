{{#if hasObservability}}
// OpenTelemetry instrumentation — must be imported before all other server modules
import './telemetry/index.{{ext}}'
{{/if}}
import { Elysia } from 'elysia'
import { cors } from '@elysiajs/cors'
import { staticPlugin } from '@elysiajs/static'
import { swagger } from '@elysiajs/swagger'
import { db } from './db/client.{{ext}}'
import { logger } from './middleware/logger.{{ext}}'
import { rateLimit } from './middleware/rateLimit.{{ext}}'
import { errorHandler } from './middleware/errorHandler.{{ext}}'
import { vaspDiagnosticRoutes } from './routes/_vasp.{{ext}}'
{{#if isSsr}}
import { csrfProtection } from './middleware/csrf.{{ext}}'
{{/if}}
{{#if hasAuth}}
import { authRoutes } from './auth/index.{{ext}}'
{{/if}}
{{#each middlewares}}
{{#if (eq scope "global")}}
{{#if (eq fn.kind "default")}}
import {{importAlias}} from '{{importPath fnSource ../ext}}'
{{else}}
import { {{importName fn}} as {{importAlias}} } from '{{importPath fnSource ../ext}}'
{{/if}}
{{/if}}
{{/each}}
{{#each queries}}
import { {{camelCase name}}Route } from './routes/queries/{{camelCase name}}.{{../ext}}'
{{/each}}
{{#each actions}}
import { {{camelCase name}}Route } from './routes/actions/{{camelCase name}}.{{../ext}}'
{{/each}}
{{#each apis}}
import { {{camelCase name}}ApiRoute } from './routes/api/{{camelCase name}}.{{../ext}}'
{{/each}}
{{#each cruds}}
import { {{camelCase entity}}CrudRoutes } from './routes/crud/{{camelCase entity}}.{{../ext}}'
{{/each}}
{{#if hasRealtime}}
import { realtimeRoutes } from './routes/realtime/index.{{ext}}'
{{/if}}
{{#each jobs}}
import { {{camelCase name}}ScheduleRoute } from './routes/jobs/{{camelCase name}}Schedule.{{../ext}}'
{{/each}}
{{#if hasAdmin}}
import { adminRoutes } from './routes/admin/index.{{ext}}'
{{/if}}
{{#each storages}}
import { {{camelCase name}}UploadRoutes } from './routes/storage/{{camelCase name}}.{{../ext}}'
{{/each}}
{{#each inboundWebhooks}}
import { {{camelCase name}}Routes } from './routes/webhooks/{{camelCase name}}.{{../ext}}'
{{/each}}
{{#if hasObservabilityMetrics}}
import { getPrometheusMetrics } from './telemetry/metrics.{{ext}}'
{{/if}}

const PORT = Number(process.env.PORT) || {{backendPort}}

{{#if envVars}}
// ── Environment variable validation ─────────────────────────────────────────
{{#each envVars}}{{#if defaultValue}}
if (!process.env.{{name}}?.trim()) process.env.{{name}} = '{{defaultValue}}'
{{/if}}{{/each}}
{
  const _envErrors = []
{{#each envVars}}
  // {{name}}: {{requirement}} {{type}}{{#if enumValues}}({{join enumValues ", "}}){{/if}}
{{#if (eq requirement "required")}}
  if (!process.env.{{name}}?.trim()) _envErrors.push('{{name}} is required{{#if (eq type "Enum")}} (must be one of: {{join enumValues ", "}}){{else if (eq type "Int")}} (must be an integer){{else if (eq type "Boolean")}} (must be "true" or "false"){{/if}}')
{{/if}}
{{#if (eq type "Int")}}
  if (process.env.{{name}} && isNaN(Number(process.env.{{name}}))) _envErrors.push('{{name}} must be an integer (got "' + process.env.{{name}} + '")')
{{/if}}
{{#if (eq type "Boolean")}}
  if (process.env.{{name}} && !['true', 'false'].includes(process.env.{{name}})) _envErrors.push('{{name}} must be "true" or "false" (got "' + process.env.{{name}} + '")')
{{/if}}
{{#if (eq type "Enum")}}
  if (process.env.{{name}} && ![{{#each enumValues}}'{{this}}'{{#unless @last}}, {{/unless}}{{/each}}].includes(process.env.{{name}})) _envErrors.push('{{name}} must be one of: {{join enumValues ", "}} (got "' + process.env.{{name}} + '")')
{{/if}}
{{#if validation.minLength}}
  if (process.env.{{name}} && process.env.{{name}}.length < {{validation.minLength}}) _envErrors.push(`{{name}} must be at least {{validation.minLength}} characters long (got ${process.env.{{name}}.length})`)
{{/if}}
{{#if validation.maxLength}}
  if (process.env.{{name}} && process.env.{{name}}.length > {{validation.maxLength}}) _envErrors.push(`{{name}} must be at most {{validation.maxLength}} characters long (got ${process.env.{{name}}.length})`)
{{/if}}
{{#if validation.startsWith}}
  if (process.env.{{name}} && !process.env.{{name}}.startsWith('{{validation.startsWith}}')) _envErrors.push('{{name}} must start with "{{validation.startsWith}}"')
{{/if}}
{{#if validation.endsWith}}
  if (process.env.{{name}} && !process.env.{{name}}.endsWith('{{validation.endsWith}}')) _envErrors.push('{{name}} must end with "{{validation.endsWith}}"')
{{/if}}
{{#if validation.min}}
  if (process.env.{{name}} && Number(process.env.{{name}}) < {{validation.min}}) _envErrors.push('{{name}} must be >= {{validation.min}} (got ' + process.env.{{name}} + ')')
{{/if}}
{{#if validation.max}}
  if (process.env.{{name}} && Number(process.env.{{name}}) > {{validation.max}}) _envErrors.push('{{name}} must be <= {{validation.max}} (got ' + process.env.{{name}} + ')')
{{/if}}
{{/each}}
  if (_envErrors.length > 0) {
    console.error('❌ Environment variable validation failed:')
    for (const _e of _envErrors) console.error('  - ' + _e)
    process.exit(1)
  }
}
{{/if}}
const app = new Elysia()
  .use(swagger({
    path: '/api/docs',
    documentation: {
      info: { title: '{{appName}} API', version: '1.0.0' },
    },
  }))
  .use(logger())
  .use(errorHandler())
  .use(cors({
    origin: process.env.CORS_ORIGIN
      ? process.env.CORS_ORIGIN.split(',').map((o) => o.trim())
      : ['http://localhost:{{frontendPort}}'{{#if hasAdmin}}, 'http://localhost:5174'{{/if}}],
    credentials: true,
  }))
  .use(rateLimit())
{{#if isSsr}}
  .use(csrfProtection())
{{/if}}
  .get('/api/health', () => ({ status: 'ok', version: '{{vaspVersion}}' }))
{{#if hasObservabilityMetrics}}
  .get('/api/metrics', async ({ set }) => {
    const body = await getPrometheusMetrics()
    set.headers['content-type'] = 'text/plain; version=0.0.4; charset=utf-8'
    return body
  })
{{/if}}
  .use(vaspDiagnosticRoutes)
{{#if hasAuth}}
  .use(authRoutes)
{{/if}}
{{#each middlewares}}
{{#if (eq scope "global")}}
  .use({{importAlias}})
{{/if}}
{{/each}}
{{#each queries}}
  .use({{camelCase name}}Route)
{{/each}}
{{#each actions}}
  .use({{camelCase name}}Route)
{{/each}}
{{#each apis}}
  .use({{camelCase name}}ApiRoute)
{{/each}}
{{#each cruds}}
  .use({{camelCase entity}}CrudRoutes)
{{/each}}
{{#if hasRealtime}}
  .use(realtimeRoutes)
{{/if}}
{{#each jobs}}
  .use({{camelCase name}}ScheduleRoute)
{{/each}}
{{#if hasAdmin}}
  .use(adminRoutes)
{{/if}}
{{#each storages}}
  .use({{camelCase name}}UploadRoutes)
{{/each}}
{{#each inboundWebhooks}}
  .use({{camelCase name}}Routes)
{{/each}}
  .listen(PORT)

console.log(`🚀 Vasp backend running at http://localhost:${PORT}`)
