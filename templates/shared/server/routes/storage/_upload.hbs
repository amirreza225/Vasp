{{! Upload route — generated by Vasp StorageGenerator }}
{{! provider: {{provider}} | block: {{storageName}} }}
import { Elysia, t } from 'elysia'
import { MAX_BYTES{{#if hasAllowedTypes}}, isMimeAllowed{{/if}}, saveFile{{#if isCloud}}, getPresignedUploadUrl{{/if}} } from '../../storage/{{storageConst}}.{{ext}}'
import { VaspError } from '../../middleware/errorHandler.{{ext}}'

export const {{storageConst}}UploadRoutes = new Elysia({ prefix: '/api/storage/{{storageConst}}' })
  /**
   * POST /api/storage/{{storageConst}}/upload
   * Accepts multipart/form-data with a single "file" field.
   * Returns { url } — the stored file URL (local path or cloud URL).
   */
  .post(
    '/upload',
    async ({ body, set }) => {
      const file = body.file
      if (!file || !(file instanceof File)) {
        set.status = 400
        throw new VaspError('BAD_REQUEST', 'No file provided', 400)
      }

      // File size validation
      if (file.size > MAX_BYTES) {
        set.status = 413
        throw new VaspError(
          'PAYLOAD_TOO_LARGE',
          `File size ${file.size} exceeds the limit of {{maxSize}}`,
          413,
        )
      }

{{#if hasAllowedTypes}}
      // MIME type validation
      if (!isMimeAllowed(file.type)) {
        set.status = 415
        throw new VaspError(
          'UNSUPPORTED_MEDIA_TYPE',
          `File type '${file.type}' is not allowed`,
          415,
        )
      }

{{/if}}
      const buffer = await file.arrayBuffer()
      const url = await saveFile(file.name, buffer{{#if isCloud}}, file.type{{/if}})

      return { url }
    },
    {
      body: t.Object({
        file: t.File(),
      }),
    },
  )
{{#if isCloud}}
  /**
   * GET /api/storage/{{storageConst}}/presign?filename=foo.jpg&contentType=image/jpeg
   * Returns a presigned URL for direct client-side upload to the cloud bucket.
   */
  .get(
    '/presign',
    async ({ query }) => {
      const { filename, contentType } = query
      if (!filename || !contentType) {
        throw new VaspError('BAD_REQUEST', 'filename and contentType are required', 400)
      }
{{#if hasAllowedTypes}}
      if (!isMimeAllowed(contentType)) {
        throw new VaspError(
          'UNSUPPORTED_MEDIA_TYPE',
          `Content type '${contentType}' is not allowed`,
          415,
        )
      }
{{/if}}
      const uploadUrl = await getPresignedUploadUrl(filename, contentType)
      return { uploadUrl, filename }
    },
    {
      query: t.Object({
        filename: t.String(),
        contentType: t.String(),
      }),
    },
  )
{{/if}}
