import { Elysia, t } from 'elysia'
import { db } from '../../db/client.{{ext}}'
import { safeParse } from 'valibot'
import { eq, sql, asc, desc, and, ilike, or } from 'drizzle-orm'
import { {{camelCase entity}}s } from '../../../drizzle/schema.{{ext}}'
import { Create{{pascalCase entity}}Schema, Update{{pascalCase entity}}Schema } from '../../../shared/validation.{{ext}}'
import { VaspError } from '../../middleware/errorHandler.{{ext}}'
{{#if needsAuth}}
import { requireAuth{{#if hasPermissions}}, PERMISSIONS{{/if}} } from '../../auth/middleware.{{ext}}'
{{/if}}
{{#if hasRealtime}}
import { publish{{pascalCase realtimeName}} } from '../realtime/{{camelCase realtimeName}}.{{ext}}'
{{/if}}
{{#if hasOutboundWebhooks}}
{{#each outboundWebhookDispatchers}}
import { dispatch{{pascalName}} } from '../../webhooks/{{camelName}}.{{../ext}}'
{{/each}}
{{/if}}
{{#if hasCacheInvalidation}}
{{#each cacheImports}}
import { invalidateCached as _invalidate{{pascalStore}} } from '../../cache/{{camelStore}}.{{../ext}}'
{{/each}}
{{/if}}

export const {{camelCase entity}}CrudRoutes = new Elysia({ prefix: '/api/crud/{{camelCase entity}}' })
{{#if needsAuth}}
  .use(requireAuth)
{{/if}}
{{#if (includes operations "list")}}
  .get('/', async ({ query{{#if needsAuth}}, user{{/if}} }) => {
    const limit = Math.min(Math.max(Number(query.limit) || 20, 1), 100)
{{#if paginate}}
    const page = Math.max(Number(query.page) || 1, 1)
    const offset = (page - 1) * limit
{{else}}
    const offset = Math.max(Number(query.offset) || 0, 0)
{{/if}}
{{#if applyTenantFilter}}
    const _tenantId = user?.{{tenantField}}
    if (_tenantId == null) throw new VaspError('AUTH_REQUIRED', 'Missing tenant context', 401)
{{/if}}
{{#if hasOwnership}}
    const _ownerId = user?.id
    if (_ownerId == null) throw new VaspError('AUTH_REQUIRED', 'Authentication required', 401)
{{/if}}

{{#if hasRelations}}
    const items = await db.query.{{camelCase entity}}s.findMany({
      with: {
{{#each withRelations}}
        {{camelCase name}}: true,
{{/each}}
      },
{{#if hasAnyRecordFilter}}
      where: (t, { eq, and }) => {{#if applyTenantFilter}}{{#if hasOwnership}}and(eq(t.{{tenantField}}, _tenantId), eq(t.{{ownershipField}}, _ownerId)){{else}}eq(t.{{tenantField}}, _tenantId){{/if}}{{else}}eq(t.{{ownershipField}}, _ownerId){{/if}},
{{/if}}
      limit,
      offset,
    })
    const [countResult] = await db.select({ count: sql`count(*)::int` }).from({{camelCase entity}}s){{#if hasAnyRecordFilter}}.where({{#if applyTenantFilter}}{{#if hasOwnership}}and(eq({{camelCase entity}}s.{{tenantField}}, _tenantId), eq({{camelCase entity}}s.{{ownershipField}}, _ownerId)){{else}}eq({{camelCase entity}}s.{{tenantField}}, _tenantId){{/if}}{{else}}eq({{camelCase entity}}s.{{ownershipField}}, _ownerId){{/if}}){{/if}}
{{#if paginate}}
    return { items, total: countResult?.count ?? 0, page, limit, offset }
{{else}}
    return { items, total: countResult?.count ?? 0, limit, offset }
{{/if}}
{{else}}
    const table = {{camelCase entity}}s

{{#if hasSortable}}
    // Allowlisted sort fields
    const SORTABLE_FIELDS = [{{#each sortableFields}}'{{this}}'{{#unless @last}}, {{/unless}}{{/each}}]
    const sortBy = SORTABLE_FIELDS.includes(query.sortBy ?? '') ? (query.sortBy as string) : 'id'
    const dirFn = query.dir === 'desc' ? desc : asc
    const orderClauses = [dirFn(table[sortBy] ?? table.id)]
{{else}}
    // Multi-column sorting: orderBy=col1,col2 & dir=asc,desc
    const orderByFields = (query.orderBy ?? 'id').split(',')
    const directions = (query.dir ?? 'asc').split(',')
    const orderClauses = orderByFields.map((field, i) => {
      const col = table[field.trim()] ?? table.id
      const dirFn = (directions[i] ?? directions[0] ?? 'asc').trim() === 'desc' ? desc : asc
      return dirFn(col)
    })
{{/if}}

    // Build WHERE conditions
    const conditions = []
{{#if applyTenantFilter}}
    // Tenant isolation: restrict results to the authenticated user's tenant
    conditions.push(eq(table.{{tenantField}}, _tenantId))
{{/if}}
{{#if hasOwnership}}
    // Ownership: restrict results to records owned by the authenticated user
    conditions.push(eq(table.{{ownershipField}}, _ownerId))
{{/if}}
{{#if hasFilterable}}
    // Allowlisted filter fields: ?filter.fieldName=value
    const FILTERABLE_FIELDS = [{{#each filterableFields}}'{{this}}'{{#unless @last}}, {{/unless}}{{/each}}]
    for (const field of FILTERABLE_FIELDS) {
      const value = (query as Record<string, string | undefined>)[`filter.${field}`]
      if (value !== undefined && table[field]) {
        conditions.push(eq(table[field], value))
      }
    }
{{else}}
    for (const [key, value] of Object.entries(query)) {
      if (!key.startsWith('filter.')) continue
      const field = key.slice(7)
      if (!table[field]) continue
      conditions.push(eq(table[field], value))
    }
{{/if}}
{{#if hasSearch}}
    // Full-text search: ?search=keyword
    if (query.search) {
      const pattern = `%${query.search}%`
      conditions.push(or({{#each searchFields}}ilike(table.{{this}}, pattern){{#unless @last}}, {{/unless}}{{/each}})!)
    }
{{/if}}
    const where = conditions.length > 0 ? and(...conditions) : undefined

    const baseQuery = db.select().from(table)
    const countQuery = db.select({ count: sql`count(*)::int` }).from(table)

    const [data, countResult] = await Promise.all([
      (where ? baseQuery.where(where) : baseQuery).orderBy(...orderClauses).limit(limit).offset(offset),
      where ? countQuery.where(where) : countQuery,
    ])

{{#if paginate}}
    return { items: data, total: countResult[0]?.count ?? 0, page, limit, offset }
{{else}}
    return { items: data, total: countResult[0]?.count ?? 0, limit, offset }
{{/if}}
{{/if}}
  }{{#if listPermission}}, {
    beforeHandle: ({ user }{{#if isTypeScript}}: { user: { role?: unknown } | null }{{/if}}) => {
      const _allowed = PERMISSIONS['{{listPermission}}'] ?? []
      if (!_allowed.includes(typeof user?.role === 'string' ? user.role : '')) {
        throw new VaspError('AUTH_FORBIDDEN', 'Insufficient permissions', 403)
      }
    },
  }{{/if}})
{{/if}}
{{#if (includes operations "create")}}
  .post('/', async ({ body, set{{#if needsAuth}}, user{{/if}} }) => {
    const parsed = safeParse(Create{{pascalCase entity}}Schema, body)
    if (!parsed.success) {
      const firstIssue = parsed.issues?.[0]
      throw new VaspError(
        'VALIDATION_FAILED',
        firstIssue?.message ?? 'Invalid request payload',
        400,
      )
    }

{{#if applyTenantFilter}}
    const _tenantId = user?.{{tenantField}}
    if (_tenantId == null) throw new VaspError('AUTH_REQUIRED', 'Missing tenant context', 401)
{{/if}}
{{#if hasOwnership}}
    const _ownerId = user?.id
    if (_ownerId == null) throw new VaspError('AUTH_REQUIRED', 'Authentication required', 401)
{{/if}}
{{#if applyTenantFilter}}
{{#if hasOwnership}}
    const [created] = await db.insert({{camelCase entity}}s).values({ ...parsed.output, {{tenantField}}: _tenantId, {{ownershipField}}: _ownerId }).returning()
{{else}}
    const [created] = await db.insert({{camelCase entity}}s).values({ ...parsed.output, {{tenantField}}: _tenantId }).returning()
{{/if}}
{{else}}
{{#if hasOwnership}}
    const [created] = await db.insert({{camelCase entity}}s).values({ ...parsed.output, {{ownershipField}}: _ownerId }).returning()
{{else}}
    const [created] = await db.insert({{camelCase entity}}s).values(parsed.output).returning()
{{/if}}
{{/if}}
{{#if hasRealtime}}
    publish{{pascalCase realtimeName}}('created', created)
{{/if}}
{{#if hasOutboundWebhooks}}
{{#each outboundWebhookDispatchers}}
{{#if hasCreated}}
    dispatch{{pascalName}}('created', created)
{{/if}}
{{/each}}
{{/if}}
{{#if createCacheInvalidations}}
{{#each createCacheInvalidations}}
    await _invalidate{{pascalStore}}('{{key}}')
{{/each}}
{{/if}}
    set.status = 201
    return created
  }{{#if createPermission}}, {
    beforeHandle: ({ user }{{#if isTypeScript}}: { user: { role?: unknown } | null }{{/if}}) => {
      const _allowed = PERMISSIONS['{{createPermission}}'] ?? []
      if (!_allowed.includes(typeof user?.role === 'string' ? user.role : '')) {
        throw new VaspError('AUTH_FORBIDDEN', 'Insufficient permissions', 403)
      }
    },
  }{{/if}})
{{/if}}
  .get('/:id', async ({ params: { id }{{#if hasAnyRecordFilter}}, user{{/if}} }) => {
    const numId = Number(id)
    if (!Number.isFinite(numId)) throw new VaspError('INVALID_INPUT', 'Invalid id', 400)
{{#if applyTenantFilter}}
    const _tenantId = user?.{{tenantField}}
    if (_tenantId == null) throw new VaspError('AUTH_REQUIRED', 'Missing tenant context', 401)
{{/if}}
{{#if hasOwnership}}
    const _ownerId = user?.id
    if (_ownerId == null) throw new VaspError('AUTH_REQUIRED', 'Authentication required', 401)
{{/if}}
{{#if hasRelations}}
    const item = await db.query.{{camelCase entity}}s.findFirst({
      where: (t, { eq, and }) => {{#if hasAnyRecordFilter}}{{#if applyTenantFilter}}{{#if hasOwnership}}and(eq(t.id, Number(id)), eq(t.{{tenantField}}, _tenantId), eq(t.{{ownershipField}}, _ownerId)){{else}}and(eq(t.id, Number(id)), eq(t.{{tenantField}}, _tenantId)){{/if}}{{else}}and(eq(t.id, Number(id)), eq(t.{{ownershipField}}, _ownerId)){{/if}}{{else}}eq(t.id, Number(id)){{/if}},
      with: {
{{#each withRelations}}
        {{camelCase name}}: true,
{{/each}}
      },
    })
{{else}}
    const [item] = await db.select().from({{camelCase entity}}s).where({{#if hasAnyRecordFilter}}{{#if applyTenantFilter}}{{#if hasOwnership}}and(eq({{camelCase entity}}s.id, Number(id)), eq({{camelCase entity}}s.{{tenantField}}, _tenantId), eq({{camelCase entity}}s.{{ownershipField}}, _ownerId)){{else}}and(eq({{camelCase entity}}s.id, Number(id)), eq({{camelCase entity}}s.{{tenantField}}, _tenantId)){{/if}}{{else}}and(eq({{camelCase entity}}s.id, Number(id)), eq({{camelCase entity}}s.{{ownershipField}}, _ownerId)){{/if}}{{else}}eq({{camelCase entity}}s.id, Number(id)){{/if}}).limit(1)
{{/if}}
    if (!item) throw new VaspError('NOT_FOUND', '{{pascalCase entity}} not found', 404)
    return item
  })
{{#if (includes operations "update")}}
  .put('/:id', async ({ params: { id }, body{{#if needsAuth}}, user{{/if}} }) => {
    const numId = Number(id)
    if (!Number.isFinite(numId)) throw new VaspError('INVALID_INPUT', 'Invalid id', 400)
    const parsed = safeParse(Update{{pascalCase entity}}Schema, body)
    if (!parsed.success) {
      const firstIssue = parsed.issues?.[0]
      throw new VaspError(
        'VALIDATION_FAILED',
        firstIssue?.message ?? 'Invalid request payload',
        400,
      )
    }

{{#if applyTenantFilter}}
    const _tenantId = user?.{{tenantField}}
    if (_tenantId == null) throw new VaspError('AUTH_REQUIRED', 'Missing tenant context', 401)
{{/if}}
{{#if hasOwnership}}
    const _ownerId = user?.id
    if (_ownerId == null) throw new VaspError('AUTH_REQUIRED', 'Authentication required', 401)
{{/if}}
    const [updated] = await db.update({{camelCase entity}}s).set(parsed.output).where({{#if hasAnyRecordFilter}}{{#if applyTenantFilter}}{{#if hasOwnership}}and(eq({{camelCase entity}}s.id, Number(id)), eq({{camelCase entity}}s.{{tenantField}}, _tenantId), eq({{camelCase entity}}s.{{ownershipField}}, _ownerId)){{else}}and(eq({{camelCase entity}}s.id, Number(id)), eq({{camelCase entity}}s.{{tenantField}}, _tenantId)){{/if}}{{else}}and(eq({{camelCase entity}}s.id, Number(id)), eq({{camelCase entity}}s.{{ownershipField}}, _ownerId)){{/if}}{{else}}eq({{camelCase entity}}s.id, Number(id)){{/if}}).returning()
    if (!updated) throw new VaspError('NOT_FOUND', '{{pascalCase entity}} not found', 404)
{{#if hasRealtime}}
    publish{{pascalCase realtimeName}}('updated', updated)
{{/if}}
{{#if hasOutboundWebhooks}}
{{#each outboundWebhookDispatchers}}
{{#if hasUpdated}}
    dispatch{{pascalName}}('updated', updated)
{{/if}}
{{/each}}
{{/if}}
{{#if updateCacheInvalidations}}
{{#each updateCacheInvalidations}}
    await _invalidate{{pascalStore}}('{{key}}')
{{/each}}
{{/if}}
    return updated
  }{{#if updatePermission}}, {
    beforeHandle: ({ user }{{#if isTypeScript}}: { user: { role?: unknown } | null }{{/if}}) => {
      const _allowed = PERMISSIONS['{{updatePermission}}'] ?? []
      if (!_allowed.includes(typeof user?.role === 'string' ? user.role : '')) {
        throw new VaspError('AUTH_FORBIDDEN', 'Insufficient permissions', 403)
      }
    },
  }{{/if}})
{{/if}}
{{#if (includes operations "delete")}}
  .delete('/:id', async ({ params: { id }{{#if needsAuth}}, user{{/if}} }) => {
    const numId = Number(id)
    if (!Number.isFinite(numId)) throw new VaspError('INVALID_INPUT', 'Invalid id', 400)
{{#if applyTenantFilter}}
    const _tenantId = user?.{{tenantField}}
    if (_tenantId == null) throw new VaspError('AUTH_REQUIRED', 'Missing tenant context', 401)
{{/if}}
{{#if hasOwnership}}
    const _ownerId = user?.id
    if (_ownerId == null) throw new VaspError('AUTH_REQUIRED', 'Authentication required', 401)
{{/if}}
    const [deleted] = await db.delete({{camelCase entity}}s).where({{#if hasAnyRecordFilter}}{{#if applyTenantFilter}}{{#if hasOwnership}}and(eq({{camelCase entity}}s.id, Number(id)), eq({{camelCase entity}}s.{{tenantField}}, _tenantId), eq({{camelCase entity}}s.{{ownershipField}}, _ownerId)){{else}}and(eq({{camelCase entity}}s.id, Number(id)), eq({{camelCase entity}}s.{{tenantField}}, _tenantId)){{/if}}{{else}}and(eq({{camelCase entity}}s.id, Number(id)), eq({{camelCase entity}}s.{{ownershipField}}, _ownerId)){{/if}}{{else}}eq({{camelCase entity}}s.id, Number(id)){{/if}}).returning()
    if (!deleted) throw new VaspError('NOT_FOUND', '{{pascalCase entity}} not found', 404)
{{#if hasRealtime}}
    publish{{pascalCase realtimeName}}('deleted', deleted)
{{/if}}
{{#if hasOutboundWebhooks}}
{{#each outboundWebhookDispatchers}}
{{#if hasDeleted}}
    dispatch{{pascalName}}('deleted', deleted)
{{/if}}
{{/each}}
{{/if}}
{{#if deleteCacheInvalidations}}
{{#each deleteCacheInvalidations}}
    await _invalidate{{pascalStore}}('{{key}}')
{{/each}}
{{/if}}
    return { ok: true }
  }{{#if deletePermission}}, {
    beforeHandle: ({ user }{{#if isTypeScript}}: { user: { role?: unknown } | null }{{/if}}) => {
      const _allowed = PERMISSIONS['{{deletePermission}}'] ?? []
