import { Elysia } from 'elysia'
import { db } from '../../db/client.{{ext}}'
import { eq, sql } from 'drizzle-orm'
import { safeParse } from 'valibot'
import { {{camelCase entity}}s } from '../../../drizzle/schema.{{ext}}'
import { Create{{pascalCase entity}}Schema, Update{{pascalCase entity}}Schema } from '../../../shared/validation.{{ext}}'
import { VaspError } from '../../middleware/errorHandler.{{ext}}'
{{#if hasAuth}}
import { requireAuth } from '../../auth/middleware.{{ext}}'
{{/if}}
{{#if hasAuth}}{{#if (eq entity auth.userEntity)}}{{#if (includes auth.methods "usernameAndPassword")}}
const MIN_PASSWORD_LENGTH = 8
{{/if}}{{/if}}{{/if}}

export const admin{{pascalCase entity}}Routes = new Elysia({ prefix: '/api/admin/{{camelCase entity}}' })
{{#if hasAuth}}
  .use(requireAuth)
{{/if}}
  .get('/', async ({ query }) => {
    const limit = Math.min(Math.max(Number(query.limit) || 20, 1), 100)
    const offset = Math.max(Number(query.offset) || 0, 0)
    const [data, countResult] = await Promise.all([
      db.select().from({{camelCase entity}}s).limit(limit).offset(offset),
      db.select({ count: sql`count(*)::int` }).from({{camelCase entity}}s),
    ])
    const items = {{#if hasAuth}}{{#if (eq entity auth.userEntity)}}data.map(({ passwordHash: _ph, ...rest }) => rest){{else}}data{{/if}}{{else}}data{{/if}}
    return { items, total: countResult[0]?.count ?? 0, limit, offset }
  })
  .get('/:id', async ({ params: { id } }) => {
    const [item] = await db.select().from({{camelCase entity}}s).where(eq({{camelCase entity}}s.id, Number(id))).limit(1)
    if (!item) throw new VaspError('NOT_FOUND', '{{pascalCase entity}} not found', 404)
{{#if hasAuth}}{{#if (eq entity auth.userEntity)}}
    const { passwordHash: _ph, ...safe } = item
    return safe
{{else}}
    return item
{{/if}}{{else}}
    return item
{{/if}}
  })
  .post('/', async ({ body, set }) => {
    const parsed = safeParse(Create{{pascalCase entity}}Schema, body)
    if (!parsed.success) {
      const firstIssue = parsed.issues?.[0]
      throw new VaspError(
        'VALIDATION_FAILED',
        firstIssue?.message ?? 'Invalid request payload',
        400,
      )
    }
{{#if hasAuth}}{{#if (eq entity auth.userEntity)}}{{#if (includes auth.methods "usernameAndPassword")}}
    const rawBody = body{{#if isTypeScript}} as Record<string, unknown>{{/if}}
    const rawPassword = typeof rawBody?.['password'] === 'string' ? rawBody['password'] : ''
    if (rawPassword.length < MIN_PASSWORD_LENGTH) {
      throw new VaspError('VALIDATION_FAILED', `Password must be at least ${MIN_PASSWORD_LENGTH} characters`, 400)
    }
    const passwordHash = await Bun.password.hash(rawPassword, 'argon2id')
    const [created] = await db.insert({{camelCase entity}}s).values({ ...parsed.output, passwordHash }).returning()
    set.status = 201
    const { passwordHash: _ph, ...safeCreated } = created
    return safeCreated
{{else}}
    const [created] = await db.insert({{camelCase entity}}s).values(parsed.output).returning()
    set.status = 201
    const { passwordHash: _ph, ...safeCreated } = created
    return safeCreated
{{/if}}{{else}}
    const [created] = await db.insert({{camelCase entity}}s).values(parsed.output).returning()
    set.status = 201
    return created
{{/if}}{{else}}
    const [created] = await db.insert({{camelCase entity}}s).values(parsed.output).returning()
    set.status = 201
    return created
{{/if}}
  })
  .put('/:id', async ({ params: { id }, body }) => {
    const parsed = safeParse(Update{{pascalCase entity}}Schema, body)
    if (!parsed.success) {
      const firstIssue = parsed.issues?.[0]
      throw new VaspError(
        'VALIDATION_FAILED',
        firstIssue?.message ?? 'Invalid request payload',
        400,
      )
    }
{{#if hasAuth}}{{#if (eq entity auth.userEntity)}}{{#if (includes auth.methods "usernameAndPassword")}}
    const rawBody = body{{#if isTypeScript}} as Record<string, unknown>{{/if}}
    const rawPassword = typeof rawBody?.['password'] === 'string' ? rawBody['password'] : ''
    if (rawPassword.length > 0 && rawPassword.length < MIN_PASSWORD_LENGTH) {
      throw new VaspError('VALIDATION_FAILED', `Password must be at least ${MIN_PASSWORD_LENGTH} characters`, 400)
    }
    const passwordHash = rawPassword.length >= MIN_PASSWORD_LENGTH ? await Bun.password.hash(rawPassword, 'argon2id') : undefined
    const [updated] = await db
      .update({{camelCase entity}}s)
      .set({ ...parsed.output, ...(passwordHash !== undefined ? { passwordHash } : {}) })
      .where(eq({{camelCase entity}}s.id, Number(id)))
      .returning()
    if (!updated) throw new VaspError('NOT_FOUND', '{{pascalCase entity}} not found', 404)
    const { passwordHash: _ph, ...safeUpdated } = updated
    return safeUpdated
{{else}}
    const [updated] = await db
      .update({{camelCase entity}}s)
      .set(parsed.output)
      .where(eq({{camelCase entity}}s.id, Number(id)))
      .returning()
    if (!updated) throw new VaspError('NOT_FOUND', '{{pascalCase entity}} not found', 404)
    const { passwordHash: _ph, ...safeUpdated } = updated
    return safeUpdated
{{/if}}{{else}}
    const [updated] = await db
      .update({{camelCase entity}}s)
      .set(parsed.output)
      .where(eq({{camelCase entity}}s.id, Number(id)))
      .returning()
    if (!updated) throw new VaspError('NOT_FOUND', '{{pascalCase entity}} not found', 404)
    return updated
{{/if}}{{else}}
    const [updated] = await db
      .update({{camelCase entity}}s)
      .set(parsed.output)
      .where(eq({{camelCase entity}}s.id, Number(id)))
      .returning()
    if (!updated) throw new VaspError('NOT_FOUND', '{{pascalCase entity}} not found', 404)
    return updated
{{/if}}
  })
  .delete('/:id', async ({ params: { id } }) => {
    const [deleted] = await db
      .delete({{camelCase entity}}s)
      .where(eq({{camelCase entity}}s.id, Number(id)))
      .returning()
    if (!deleted) throw new VaspError('NOT_FOUND', '{{pascalCase entity}} not found', 404)
    return { ok: true }
  })
