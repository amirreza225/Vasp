import * as v from 'valibot'

{{#each entities}}
export const Create{{pascalCase name}}Schema = v.object({
{{#each fields}}
{{#if isRelation}}
{{#unless isArray}}
  {{name}}Id: {{valibotSchema "Int" nullable nullable}},
{{/unless}}
{{else}}
{{#unless (includes modifiers "id")}}
{{#unless isUpdatedAt}}
{{#unless (includes modifiers "default_now")}}
  {{name}}: {{{valibotSchema type nullable nullable enumValues validation config.validate}}},
{{/unless}}
{{/unless}}
{{/unless}}
{{/if}}
{{/each}}
})

export const Update{{pascalCase name}}Schema = v.partial(Create{{pascalCase name}}Schema)

{{/each}}