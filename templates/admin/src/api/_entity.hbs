import axios from 'axios'

const http = axios.create({
  baseURL: '/api/admin',
  withCredentials: true,
})

http.interceptors.response.use(
  (response) => response,
  (error) => {
    const serverError = error?.response?.data?.error
    if (serverError?.message) {
      error.message = serverError.message
    }
    if (serverError?.code) {
      error.errorCode = serverError.code
    }
    if (serverError?.stack) {
      error.serverStack = serverError.stack
    }
    return Promise.reject(error)
  },
)

export const {{pascalCase name}}Api = {
  list: (params) => http.get('/{{camelCase name}}', { params }).then(r => r.data),
  get: (id) => http.get(`/{{camelCase name}}/${id}`).then(r => r.data),
  create: (data) => http.post('/{{camelCase name}}', data).then(r => r.data),
  update: (id, data) => http.put(`/{{camelCase name}}/${id}`, data).then(r => r.data),
  remove: (id) => http.delete(`/{{camelCase name}}/${id}`).then(r => r.data),
}
