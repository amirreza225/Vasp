import { createRouter, createWebHistory } from 'vue-router'
import AdminLayout from '@/layouts/AdminLayout.vue'
import Dashboard from '@/views/dashboard/index.vue'
{{#each adminEntities}}
import {{pascalCase name}}List from '@/views/{{kebabCase name}}/index.vue'
{{/each}}
{{#if hasAuth}}
import LoginPage from '@/views/login/index.vue'
import { adminAuthChecked, currentAdminUser } from '@/composables/useAdminAuth.{{ext}}'
{{/if}}

export const router = createRouter({
  history: createWebHistory(),
  routes: [
{{#if hasAuth}}
    {
      path: '/login',
      component: LoginPage,
      meta: { public: true },
    },
{{/if}}
    {
      path: '/',
      component: AdminLayout,
      children: [
        { path: '', redirect: '/dashboard' },
        {
          path: 'dashboard',
          component: Dashboard,
          meta: { title: 'Dashboard' },
        },
{{#each adminEntities}}
        {
          path: '{{kebabCase name}}',
          component: {{pascalCase name}}List,
          meta: { title: '{{pascalCase name}} Management' },
        },
{{/each}}
      ],
    },
  ],
})

{{#if hasAuth}}
router.beforeEach(async (to) => {
  if (to.meta.public) return true

  // If already checked and logged in, allow
  if (adminAuthChecked.value && currentAdminUser.value) return true

  // Fetch current user once
  if (!adminAuthChecked.value) {
    try {
      const res = await fetch('/api/auth/me', { credentials: 'include' })
      if (res.ok) {
        const data = await res.json()
        currentAdminUser.value = data
      }
    } catch {
      // ignore
    }
    adminAuthChecked.value = true
  }

  if (!currentAdminUser.value) return '/login'
  return true
})
{{/if}}
