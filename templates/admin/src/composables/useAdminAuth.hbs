import { ref } from 'vue'
import { useRouter } from 'vue-router'

export const currentAdminUser = ref(null)
export const adminAuthChecked = ref(false)

async function apiFetch(url, options = {}) {
  const res = await fetch(url, { credentials: 'include', ...options })
  if (!res.ok) {
    const body = await res.json().catch(() => ({}))
    throw new Error(body?.error?.message ?? body?.error ?? `HTTP ${res.status}`)
  }
  return res.json()
}

export function useAdminAuth() {
  const router = useRouter()

  async function login(username, password) {
    await apiFetch('/api/auth/login', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ username, password }),
    })
    await refreshUser()
    await router.push('/dashboard')
  }

  async function logout() {
    await fetch('/api/auth/logout', { method: 'POST', credentials: 'include' })
    currentAdminUser.value = null
    adminAuthChecked.value = false
    await router.push('/login')
  }

  async function refreshUser() {
    try {
      const data = await apiFetch('/api/auth/me')
      currentAdminUser.value = data
    } catch {
      currentAdminUser.value = null
    }
  }

  async function checkAuth() {
    if (adminAuthChecked.value) return !!currentAdminUser.value
    try {
      const data = await apiFetch('/api/auth/me')
      currentAdminUser.value = data
      adminAuthChecked.value = true
      return true
    } catch {
      currentAdminUser.value = null
      adminAuthChecked.value = true
      return false
    }
  }

  return { currentAdminUser, adminAuthChecked, login, logout, checkAuth, refreshUser }
}
