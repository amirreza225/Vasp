<script setup{{#if isTypeScript}} lang="ts"{{/if}}>
import { ref, watch{{#if hasManyToOneRelations}}, onMounted{{/if}} } from 'vue'
import Dialog from 'primevue/dialog'
import Button from 'primevue/button'
import InputText from 'primevue/inputtext'
import InputNumber from 'primevue/inputnumber'
import Textarea from 'primevue/textarea'
import Select from 'primevue/select'
import ToggleSwitch from 'primevue/toggleswitch'
import Password from 'primevue/password'
import { useToast } from 'primevue/usetoast'
import { {{pascalCase name}}Api } from '../../api/{{kebabCase name}}.js'
{{#each uniqueRelatedEntities}}
import { {{pascalCase this}}Api } from '../../api/{{kebabCase this}}.js'
{{/each}}

const props = defineProps({
  visible: Boolean,
  record: Object,
})

const emit = defineEmits(['close', 'saved'])

const toast = useToast()

// JSON fields need string ↔ object conversion
const jsonFields = [{{#each fields}}{{#unless isRelation}}{{#if (eq type "Json")}}'{{name}}', {{/if}}{{/unless}}{{/each}}]
// Nullable DateTime fields — convert empty string to null before submitting
const nullableDateTimeFields = [{{#each fields}}{{#unless isRelation}}{{#unless (includes modifiers "id")}}{{#unless isUpdatedAt}}{{#unless (includes modifiers "default_now")}}{{#if (eq type "DateTime")}}{{#if nullable}}'{{name}}', {{/if}}{{/if}}{{/unless}}{{/unless}}{{/unless}}{{/unless}}{{/each}}]
// Nullable String/Text fields — convert empty string to null before submitting
const nullableStringTextFields = [{{#each fields}}{{#unless isRelation}}{{#unless (includes modifiers "id")}}{{#unless isUpdatedAt}}{{#unless (includes modifiers "default_now")}}{{#if nullable}}{{#if (eq type "String")}}'{{name}}', {{/if}}{{#if (eq type "Text")}}'{{name}}', {{/if}}{{/if}}{{/unless}}{{/unless}}{{/unless}}{{/unless}}{{/each}}]

// Options for relation selects (loaded on mount)
{{#each manyToOneRelations}}const {{name}}Options = ref([])
{{/each}}
function emptyForm() {
  return {
{{#each fields}}
{{#unless isRelation}}
{{#unless isExplicitFkDuplicate}}
{{#unless (includes modifiers "id")}}
{{#unless isUpdatedAt}}
{{#unless (includes modifiers "default_now")}}
    {{name}}: {{#if (eq type "Boolean")}}false{{else if (eq type "Int")}}0{{else if (eq type "Float")}}0{{else if (eq type "Enum")}}{{#if enumValues}}'{{enumValues.[0]}}'{{else}}''{{/if}}{{else if (eq type "DateTime")}}{{#if nullable}}null{{else}}''{{/if}}{{else if (eq type "Json")}}'{}'{{else if nullable}}null{{else}}''{{/if}},
{{/unless}}
{{/unless}}
{{/unless}}
{{/unless}}
{{/unless}}
{{/each}}
{{#each manyToOneRelations}}    {{fkName}}: null,
{{/each}}{{#if hasAuth}}{{#if (eq name auth.userEntity)}}{{#if (includes auth.methods "usernameAndPassword")}}
    password: '',
{{/if}}{{/if}}{{/if}}
  }
}

const form = ref(emptyForm())
const loading = ref(false)

watch(() => props.record, (val) => {
  if (val) {
    const copy = { ...val }
    for (const k of jsonFields) {
      if (copy[k] != null) {
        copy[k] = typeof copy[k] === 'string' ? copy[k] : JSON.stringify(copy[k], null, 2)
      }
    }
    form.value = copy
  } else {
    form.value = emptyForm()
  }
}, { immediate: true })

{{#if hasManyToOneRelations}}
onMounted(async () => {
{{#each manyToOneRelations}}  try {
    const res = await {{pascalCase relatedEntity}}Api.list({ limit: 100, offset: 0 })
    // Label uses common display fields in priority order; falls back to the record's id.
    {{name}}Options.value = (res?.items ?? []).map((r) => ({
      label: String(r.name ?? r.title ?? r.username ?? r.email ?? r.id),
      value: r.id,
    }))
  } catch { /* ignore — options stay empty */ }
{{/each}}
})
{{/if}}

async function handleSubmit() {
  loading.value = true
  try {
    const payload = { ...form.value }
    for (const k of jsonFields) {
      if (payload[k] && typeof payload[k] === 'string') {
        try { payload[k] = JSON.parse(payload[k]) } catch {
          toast.add({ severity: 'error', summary: 'Invalid JSON', detail: `Field "${k}" must be valid JSON`, life: 4000 })
          return
        }
      }
    }
    for (const k of nullableDateTimeFields) {
      if (payload[k] === '') payload[k] = null
    }
    for (const k of nullableStringTextFields) {
      if (payload[k] === '') payload[k] = null
    }
    if (props.record?.id) {
      await {{pascalCase name}}Api.update(props.record.id, payload)
    } else {
      await {{pascalCase name}}Api.create(payload)
    }
    emit('saved')
  } catch (err) {
    toast.add({ severity: 'error', summary: 'Save Failed', detail: err instanceof Error ? err.message : 'An error occurred', life: 4000 })
  } finally {
    loading.value = false
  }
}
</script>

<template>
  <Dialog
    :visible="visible"
    :header="record?.id ? 'Edit {{pascalCase name}}' : 'Create {{pascalCase name}}'"
    :style="{ width: '560px' }"
    modal
    @update:visible="emit('close')"
  >
    <div class="vasp-admin-form">
{{#each fields}}
{{#unless isRelation}}
{{#unless (includes modifiers "id")}}
{{#unless isUpdatedAt}}
{{#unless (includes modifiers "default_now")}}
      <div class="vasp-admin-form-field">
        <label class="vasp-admin-form-label">{{pascalCase name}}{{#if nullable}} <span class="vasp-optional">(optional)</span>{{/if}}</label>
{{#if (eq type "Boolean")}}
        <ToggleSwitch v-model="form.{{name}}" />
{{else if (eq type "Int")}}
        <InputNumber v-model="form.{{name}}" :use-grouping="false" class="w-full" />
{{else if (eq type "Float")}}
        <InputNumber v-model="form.{{name}}" :min-fraction-digits="1" :max-fraction-digits="4" class="w-full" />
{{else if (eq type "DateTime")}}
        <InputText v-model="form.{{name}}" placeholder="YYYY-MM-DD HH:MM:SS" class="w-full" />
{{else if (eq type "Text")}}
        <Textarea v-model="form.{{name}}" :rows="4" class="w-full" auto-resize />
{{else if (eq type "Json")}}
        <Textarea v-model="form.{{name}}" :rows="4" class="w-full vasp-monospace" placeholder="{}" />
{{else if (eq type "Enum")}}
        <Select
          v-model="form.{{name}}"
          :options="[{{#each enumValues}}'{{this}}'{{#unless @last}}, {{/unless}}{{/each}}]"
          class="w-full"
        />
{{else}}
        <InputText v-model="form.{{name}}" class="w-full" />
{{/if}}
      </div>
{{/unless}}
{{/unless}}
{{/unless}}
{{/unless}}
{{/each}}
{{#each manyToOneRelations}}
      <div class="vasp-admin-form-field">
        <label class="vasp-admin-form-label">{{pascalCase name}}{{#if nullable}} <span class="vasp-optional">(optional)</span>{{/if}}</label>
        <Select
          v-model="form.{{fkName}}"
          :options="{{name}}Options"
          option-label="label"
          option-value="value"
          placeholder="Select {{pascalCase relatedEntity}}"
          filter
          {{#if nullable}}:show-clear="true"{{/if}}
          class="w-full"
        />
      </div>
{{/each}}
{{#if hasAuth}}{{#if (eq name auth.userEntity)}}{{#if (includes auth.methods "usernameAndPassword")}}
      <div class="vasp-admin-form-field">
        <label class="vasp-admin-form-label">\{{ record?.id ? 'New Password' : 'Password' }}</label>
        <Password v-model="form.password" :feedback="false" placeholder="Min. 8 characters" class="w-full" />
        <small class="vasp-field-hint">\{{ record?.id ? 'Leave blank to keep current password' : 'Required, min. 8 characters' }}</small>
      </div>
{{/if}}{{/if}}{{/if}}
    </div>
    <template #footer>
      <Button label="Cancel" severity="secondary" outlined @click="emit('close')" />
      <Button label="Save" :loading="loading" @click="handleSubmit" />
    </template>
  </Dialog>
</template>

<style scoped>
.vasp-admin-form {
  display: flex;
  flex-direction: column;
  gap: 16px;
  padding: 4px 0;
}

.vasp-admin-form-field {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.vasp-admin-form-label {
  font-weight: 500;
  font-size: 14px;
}

.vasp-optional {
  font-weight: 400;
  color: var(--p-surface-400, #adb5bd);
  font-size: 12px;
}

.vasp-field-hint {
  color: var(--p-surface-500, #868e96);
  font-size: 12px;
}

.vasp-monospace {
  font-family: monospace;
}
</style>
