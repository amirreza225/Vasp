  nuxtApp.provide('vasp', {
    async query<T = unknown>(name: string, args?: unknown): Promise<T> {
      if (!queryFns[name]) throw new Error(`[Vasp] Unknown query: ${name}`)
      return queryFns[name](args) as Promise<T>
