{
  "workspaces": {
    ".": {
      "entry": ["e2e/**/*.mts", "playwright*.config.mts"],
      "ignoreDependencies": ["prettier"]
    },
    "packages/cli": {
      "entry": ["src/index.ts", "bin/vasp.ts"]
    },
    "packages/core": {},
    "packages/parser": {},
    "packages/generator": {
      "entry": ["src/generate.ts"]
    },
    "packages/runtime": {
      "entry": [
        "src/client/composables/*.ts",
        "src/client/ofetch.ts"
      ]
    }
  },
  "ignore": [
    "packages/cli/src/utils/prompt.ts",
    "packages/generator/src/GeneratorContext.ts",
    "packages/cli/src/commands/generate.ts"
  ]
}
